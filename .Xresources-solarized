! Solarized color scheme for the X Window System
!
! http://ethanschoonover.com/solarized

# SOLARIZED  HEX      ANSI(HEX)  TERMCOL    REMARKS        USAGE
# ---------  -------  ---------  ---------  -------------  --------------------
# base03     #002b36  8  / 0x8   brblack    bg primary
# base02     #073642  0  / 0x0   black      bg highlights
# base01     #586e75  10 / 0xa   brgreen    fg secondary
# base00     #657b83  11 / 0xb   bryellow   -
# base0      #839496  12 / 0xc   brblue     fg primary
# base1      #93a1a1  14 / 0xe   brcyan     fg highlights
# base2      #eee8d5  7  / 0x7   white      -
# base3      #fdf6e3  15 / 0xf   brwhite    -
# yellow     #b58900  3  / 0x3   yellow     accent         ternary "in-between"
# orange     #cb4b16  9  / 0x9   brred      accent         boolean/ternary "no"
# red        #dc322f  1  / 0x1   red        accent (#3)
# magenta    #d33682  5  / 0x5   magenta    accent         standout
# violet     #6c71c4  13 / 0xd   brmagenta  accent
# blue       #268bd2  4  / 0x4   blue       accent
# cyan       #2aa198  6  / 0x6   cyan       accent (#1)
# green      #859900  2  / 0x2   green      accent (#2)    boolean/ternary "yes"

#if !defined(DARK) && !defined(LIGHT)
# define DARK
#endif

! Common

#define S_yellow        #b58900
#define S_orange        #cb4b16
#define S_red           #dc322f
#define S_magenta       #d33682
#define S_violet        #6c71c4
#define S_blue          #268bd2
#define S_cyan          #2aa198
#define S_green         #859900


! Dark

#if defined(DARK)
#define S_base03        #002b36
#define S_base02        #073642
#define S_base01        #586e75
#define S_base00        #657b83
#define S_base0         #839496
#define S_base1         #93a1a1
#define S_base2         #eee8d5
#define S_base3         #fdf6e3
#endif


! Light

#if defined(LIGHT)
#define S_base03        #fdf6e3
#define S_base02        #eee8d5
#define S_base01        #93a1a1
#define S_base00        #839496
#define S_base0         #657b83
#define S_base1         #586e75
#define S_base2         #073642
#define S_base3         #002b36
#endif


! To only apply colors to your terminal, for example, prefix
! the color assignment statement with its name. Example:
!
! URxvt*background:            S_base03

*background:              S_base03
*foreground:              S_base0
*fading:                  40
*fadeColor:               S_base03
*cursorColor:             S_base1

*color0:                  S_base02
*color1:                  S_red
*color2:                  S_green
*color3:                  S_yellow
*color4:                  S_blue
*color5:                  S_magenta
*color6:                  S_cyan
*color7:                  S_base2
*color8:                  S_base03
*color9:                  S_orange
*color10:                 S_base01
*color11:                 S_base00
*color12:                 S_base0
*color13:                 S_violet
*color14:                 S_base1
*color15:                 S_base3

